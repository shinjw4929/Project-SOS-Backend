{
  "uid": "service-overview",
  "title": "Service Overview",
  "tags": ["project-sos"],
  "timezone": "utc",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, level, count() AS count FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY time, level ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Level Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT level, count() AS count FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY level ORDER BY count DESC",
          "refId": "A",
          "format": 2
        }
      ]
    },
    {
      "id": 3,
      "title": "Category Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT category, count() AS count FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY category ORDER BY count DESC",
          "refId": "A",
          "format": 2
        }
      ]
    },
    {
      "id": 4,
      "title": "Events by Category (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, category, count() AS count FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY time, category ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "title": "Warnings & Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, level, count() AS count FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND level IN ('WARNING', 'ERROR') GROUP BY time, level ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "title": "Total Events",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT count() AS total FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime",
          "refId": "A",
          "format": 2
        }
      ]
    },
    {
      "id": 7,
      "title": "Warnings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 16 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT count() AS warnings FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND level = 'WARNING'",
          "refId": "A",
          "format": 2
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } }
      }
    },
    {
      "id": 8,
      "title": "Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 16 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT count() AS errors FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND level = 'ERROR'",
          "refId": "A",
          "format": 2
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 9,
      "title": "Recent Warnings & Errors",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toString(timestamp) AS time, level, category, world, message FROM project_sos.service_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND level IN ('WARNING', 'ERROR') ORDER BY timestamp DESC LIMIT 100",
          "refId": "A",
          "format": 2
        }
      ]
    }
  ],
  "schemaVersion": 39
}
